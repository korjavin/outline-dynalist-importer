OUTLINE_URL=https://outline.example.com
OUTLINE_API_KEY=ol_api_your_key_here
OUTLINE_COLLECTION_NAME=dynalist
SOURCE_FOLDER=/absolute/path/to/dynalist-backup-YYYY-MM-DD
# Seconds between API calls. Outline rate-limits documents.create per minute;
# 5s (~12/min) is conservative and safe.
REQ_DELAY=5.0
